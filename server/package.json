{
  "name": "gharpayy-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Gharpayy CRM backend — Fastify + Mongo + Auth.js + Socket.IO + BullMQ. Deploy to VPS, NOT to Lovable.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "start": "node dist/server/src/index.js",
    "worker": "tsx src/workers/index.ts",
    "worker:prod": "node dist/server/src/workers/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.5",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "libphonenumber-js": "^1.12.42",
    "mongodb": "^6.12.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
